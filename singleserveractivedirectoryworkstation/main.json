{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "projectName": {
      "type": "string",
      "minLength": 2,
      "maxLength": 8,
      "metadata": {
        "description": "Project name. Use 2 to 8 characters. This value is used in Azure resource names and the Windows Server computer name."
      }
    },
    "adminUsername": {
      "type": "string",
      "metadata": {
        "description": "Local administrator username for both VMs. This account is also used for the domain join attempt."
      }
    },
    "adminPassword": {
      "type": "securestring",
      "metadata": {
        "description": "Local administrator password for both VMs and the Active Directory DSRM password."
      }
    },
    "sourceIpAddress": {
      "type": "string",
      "metadata": {
        "description": "Public IPv4 address that is allowed to connect with RDP. Enter only the IP address, without /32."
      }
    },
    "serverVmSize": {
      "type": "string",
      "defaultValue": "Standard_D2as_v7",
      "metadata": {
        "description": "Azure VM size for the Windows Server / Active Directory VM."
      }
    },
    "workstationVmSize": {
      "type": "string",
      "defaultValue": "Standard_D2as_v7",
      "metadata": {
        "description": "Azure VM size for the Windows 11 workstation VM."
      }
    },
    "domainName": {
      "type": "string",
      "metadata": {
        "description": "Active Directory domain name. Example: contoso.local or ad.contoso.com."
      }
    },
    "domainNetbiosName": {
      "type": "string",
      "minLength": 1,
      "maxLength": 15,
      "metadata": {
        "description": "Active Directory NetBIOS name. Use 1 to 15 characters."
      }
    },
    "joinWorkstationToDomain": {
      "type": "bool",
      "defaultValue": true,
      "metadata": {
        "description": "Join the Windows 11 workstation to the new Active Directory domain after the domain controller has been promoted."
      }
    },
    "tags": {
      "type": "object",
      "defaultValue": {},
      "metadata": {
        "description": "Add Azure resource tags as a JSON object. Leave empty if no tags are needed."
      }
    }
  },
  "variables": {
    "location": "[resourceGroup().location]",
    "vnetAddressPrefix": "10.69.0.0/16",
    "subnetPrefix": "10.69.0.0/24",
    "serverPrivateIpAddress": "10.69.0.4",
    "workstationPrivateIpAddress": "10.69.0.5",
    "lowerProjectName": "[toLower(parameters('projectName'))]",
    "namePrefix": "[format('jv-{0}', variables('lowerProjectName'))]",
    "vnetName": "[format('vnet-{0}', variables('namePrefix'))]",
    "subnetName": "[format('snet-{0}', variables('namePrefix'))]",
    "nsgName": "[format('nsg-{0}', variables('namePrefix'))]",
    "serverPublicIpName": "[format('pip-{0}', variables('namePrefix'))]",
    "serverNicName": "[format('nic-{0}', variables('namePrefix'))]",
    "serverVmName": "[format('vm-{0}', variables('namePrefix'))]",
    "serverOsDiskName": "[format('osdisk-{0}', variables('namePrefix'))]",
    "workstationPublicIpName": "pip-jv-ws01",
    "workstationNicName": "nic-jv-ws01",
    "workstationVmName": "vm-jv-ws01",
    "workstationOsDiskName": "osdisk-jv-ws01",
    "rdpRuleName": "Allow-RDP-Inbound",
    "encodedAdminPassword": "[base64(parameters('adminPassword'))]",
    "installAdScriptLines": [
      "$ErrorActionPreference = 'Stop'",
      "Install-WindowsFeature AD-Domain-Services -IncludeManagementTools",
      "[format('$adminPasswordPlain = [System.Text.Encoding]::UTF8.GetString([System.Convert]::FromBase64String(''{0}''))', variables('encodedAdminPassword'))]",
      "$securePassword = ConvertTo-SecureString $adminPasswordPlain -AsPlainText -Force",
      "[format('Install-ADDSForest -DomainName ''{0}'' -DomainNetbiosName ''{1}'' -SafeModeAdministratorPassword $securePassword -InstallDNS -Force -NoRebootOnCompletion:$true', parameters('domainName'), parameters('domainNetbiosName'))]",
      "$adminPasswordPlain = $null",
      "shutdown.exe /r /t 60 /c 'Restart after Active Directory Domain Services installation'",
      "exit 0"
    ],
    "installAdCommand": "[format('powershell.exe -ExecutionPolicy Unrestricted -NoProfile -Command \"{0}\"', join(variables('installAdScriptLines'), '; '))]",
    "joinDomainScriptLines": [
      "$ErrorActionPreference = 'Stop'",
      "[format('$adminPasswordPlain = [System.Text.Encoding]::UTF8.GetString([System.Convert]::FromBase64String(''{0}''))', variables('encodedAdminPassword'))]",
      "$securePassword = ConvertTo-SecureString $adminPasswordPlain -AsPlainText -Force",
      "[format('$credential = New-Object System.Management.Automation.PSCredential(''{0}\\{1}'', $securePassword)', parameters('domainNetbiosName'), parameters('adminUsername'))]",
      "[format('$domainName = ''{0}''', parameters('domainName'))]",
      "[format('$dcIp = ''{0}''', variables('serverPrivateIpAddress'))]",
      "$adapter = Get-NetAdapter | Where-Object { $_.Status -eq 'Up' -and $_.HardwareInterface } | Sort-Object -Property ifIndex | Select-Object -First 1",
      "if (-not $adapter) { throw 'No active network adapter found.' }",
      "Set-DnsClientServerAddress -InterfaceIndex $adapter.ifIndex -ServerAddresses $dcIp",
      "ipconfig.exe /flushdns | Out-Null",
      "$srvRecord = '_ldap._tcp.dc._msdcs.' + $domainName",
      "$timeout = (Get-Date).AddMinutes(90)",
      "$domainReady = $false",
      "do { try { Resolve-DnsName -Name $domainName -Server $dcIp -ErrorAction Stop | Out-Null; Resolve-DnsName -Name $srvRecord -Type SRV -Server $dcIp -ErrorAction Stop | Out-Null; foreach ($port in 53,88,135,389,445) { $tcpReady = Test-NetConnection -ComputerName $dcIp -Port $port -InformationLevel Quiet -WarningAction SilentlyContinue; if (-not $tcpReady) { throw ('TCP port ' + $port + ' on domain controller is not reachable.') } }; nltest.exe /dsgetdc:$domainName /force | Out-Null; if ($LASTEXITCODE -ne 0) { throw 'Domain controller discovery failed.' }; $domainReady = $true } catch { Write-Host ('Domain not ready yet: ' + $_.Exception.Message); Start-Sleep -Seconds 30; ipconfig.exe /flushdns | Out-Null } } until ($domainReady -or ((Get-Date) -gt $timeout))",
      "if (-not $domainReady) { throw 'Domain controller was not reachable before timeout.' }",
      "Add-Computer -DomainName $domainName -Credential $credential -Restart -Force -ErrorAction Stop",
      "$adminPasswordPlain = $null",
      "exit 0"
    ],
    "joinDomainCommand": "[format('powershell.exe -ExecutionPolicy Unrestricted -NoProfile -Command \"{0}\"', join(variables('joinDomainScriptLines'), '; '))]"
  },
  "resources": [
    {
      "type": "Microsoft.Network/networkSecurityGroups",
      "apiVersion": "2023-11-01",
      "name": "[variables('nsgName')]",
      "location": "[variables('location')]",
      "tags": "[parameters('tags')]",
      "properties": {
        "securityRules": [
          {
            "name": "[variables('rdpRuleName')]",
            "properties": {
              "priority": 1000,
              "direction": "Inbound",
              "access": "Allow",
              "protocol": "Tcp",
              "sourcePortRange": "*",
              "destinationPortRange": "3389",
              "sourceAddressPrefix": "[format('{0}/32', parameters('sourceIpAddress'))]",
              "destinationAddressPrefix": "*",
              "description": "Allow RDP only from the configured administrator IP address."
            }
          }
        ]
      }
    },
    {
      "type": "Microsoft.Network/virtualNetworks",
      "apiVersion": "2023-11-01",
      "name": "[variables('vnetName')]",
      "location": "[variables('location')]",
      "tags": "[parameters('tags')]",
      "properties": {
        "addressSpace": {
          "addressPrefixes": [
            "[variables('vnetAddressPrefix')]"
          ]
        },
        "dhcpOptions": {
          "dnsServers": [
            "[variables('serverPrivateIpAddress')]"
          ]
        },
        "subnets": [
          {
            "name": "[variables('subnetName')]",
            "properties": {
              "addressPrefix": "[variables('subnetPrefix')]",
              "networkSecurityGroup": {
                "id": "[resourceId('Microsoft.Network/networkSecurityGroups', variables('nsgName'))]"
              }
            }
          }
        ]
      },
      "dependsOn": [
        "[resourceId('Microsoft.Network/networkSecurityGroups', variables('nsgName'))]"
      ]
    },
    {
      "type": "Microsoft.Network/publicIPAddresses",
      "apiVersion": "2023-11-01",
      "name": "[variables('serverPublicIpName')]",
      "location": "[variables('location')]",
      "tags": "[parameters('tags')]",
      "sku": {
        "name": "Standard"
      },
      "properties": {
        "publicIPAllocationMethod": "Static"
      }
    },
    {
      "type": "Microsoft.Network/publicIPAddresses",
      "apiVersion": "2023-11-01",
      "name": "[variables('workstationPublicIpName')]",
      "location": "[variables('location')]",
      "tags": "[parameters('tags')]",
      "sku": {
        "name": "Standard"
      },
      "properties": {
        "publicIPAllocationMethod": "Static"
      }
    },
    {
      "type": "Microsoft.Network/networkInterfaces",
      "apiVersion": "2023-11-01",
      "name": "[variables('serverNicName')]",
      "location": "[variables('location')]",
      "tags": "[parameters('tags')]",
      "properties": {
        "ipConfigurations": [
          {
            "name": "ipconfig1",
            "properties": {
              "privateIPAllocationMethod": "Static",
              "privateIPAddress": "[variables('serverPrivateIpAddress')]",
              "subnet": {
                "id": "[resourceId('Microsoft.Network/virtualNetworks/subnets', variables('vnetName'), variables('subnetName'))]"
              },
              "publicIPAddress": {
                "id": "[resourceId('Microsoft.Network/publicIPAddresses', variables('serverPublicIpName'))]"
              }
            }
          }
        ],
        "dnsSettings": {
          "dnsServers": [
            "[variables('serverPrivateIpAddress')]"
          ]
        }
      },
      "dependsOn": [
        "[resourceId('Microsoft.Network/publicIPAddresses', variables('serverPublicIpName'))]",
        "[resourceId('Microsoft.Network/virtualNetworks', variables('vnetName'))]"
      ]
    },
    {
      "type": "Microsoft.Network/networkInterfaces",
      "apiVersion": "2023-11-01",
      "name": "[variables('workstationNicName')]",
      "location": "[variables('location')]",
      "tags": "[parameters('tags')]",
      "properties": {
        "ipConfigurations": [
          {
            "name": "ipconfig1",
            "properties": {
              "privateIPAllocationMethod": "Static",
              "privateIPAddress": "[variables('workstationPrivateIpAddress')]",
              "subnet": {
                "id": "[resourceId('Microsoft.Network/virtualNetworks/subnets', variables('vnetName'), variables('subnetName'))]"
              },
              "publicIPAddress": {
                "id": "[resourceId('Microsoft.Network/publicIPAddresses', variables('workstationPublicIpName'))]"
              }
            }
          }
        ],
        "dnsSettings": {
          "dnsServers": [
            "[variables('serverPrivateIpAddress')]"
          ]
        }
      },
      "dependsOn": [
        "[resourceId('Microsoft.Network/publicIPAddresses', variables('workstationPublicIpName'))]",
        "[resourceId('Microsoft.Network/virtualNetworks', variables('vnetName'))]"
      ]
    },
    {
      "type": "Microsoft.Compute/virtualMachines",
      "apiVersion": "2023-09-01",
      "name": "[variables('serverVmName')]",
      "location": "[variables('location')]",
      "tags": "[parameters('tags')]",
      "properties": {
        "hardwareProfile": {
          "vmSize": "[parameters('serverVmSize')]"
        },
        "osProfile": {
          "computerName": "[variables('serverVmName')]",
          "adminUsername": "[parameters('adminUsername')]",
          "adminPassword": "[parameters('adminPassword')]",
          "windowsConfiguration": {
            "provisionVMAgent": true,
            "enableAutomaticUpdates": true
          }
        },
        "storageProfile": {
          "imageReference": {
            "publisher": "MicrosoftWindowsServer",
            "offer": "WindowsServer",
            "sku": "2022-datacenter-azure-edition",
            "version": "latest"
          },
          "osDisk": {
            "name": "[variables('serverOsDiskName')]",
            "createOption": "FromImage",
            "managedDisk": {
              "storageAccountType": "Premium_LRS"
            }
          }
        },
        "networkProfile": {
          "networkInterfaces": [
            {
              "id": "[resourceId('Microsoft.Network/networkInterfaces', variables('serverNicName'))]",
              "properties": {
                "primary": true
              }
            }
          ]
        },
        "diagnosticsProfile": {
          "bootDiagnostics": {
            "enabled": true
          }
        }
      },
      "dependsOn": [
        "[resourceId('Microsoft.Network/networkInterfaces', variables('serverNicName'))]"
      ]
    },
    {
      "type": "Microsoft.Compute/virtualMachines",
      "apiVersion": "2023-09-01",
      "name": "[variables('workstationVmName')]",
      "location": "[variables('location')]",
      "tags": "[parameters('tags')]",
      "properties": {
        "hardwareProfile": {
          "vmSize": "[parameters('workstationVmSize')]"
        },
        "osProfile": {
          "computerName": "[variables('workstationVmName')]",
          "adminUsername": "[parameters('adminUsername')]",
          "adminPassword": "[parameters('adminPassword')]",
          "windowsConfiguration": {
            "provisionVMAgent": true,
            "enableAutomaticUpdates": true
          }
        },
        "storageProfile": {
          "imageReference": {
            "publisher": "MicrosoftWindowsDesktop",
            "offer": "windows-11",
            "sku": "win11-25h2-pro",
            "version": "latest"
          },
          "osDisk": {
            "name": "[variables('workstationOsDiskName')]",
            "createOption": "FromImage",
            "managedDisk": {
              "storageAccountType": "Premium_LRS"
            }
          }
        },
        "networkProfile": {
          "networkInterfaces": [
            {
              "id": "[resourceId('Microsoft.Network/networkInterfaces', variables('workstationNicName'))]",
              "properties": {
                "primary": true
              }
            }
          ]
        },
        "diagnosticsProfile": {
          "bootDiagnostics": {
            "enabled": true
          }
        }
      },
      "dependsOn": [
        "[resourceId('Microsoft.Network/networkInterfaces', variables('workstationNicName'))]"
      ]
    },
    {
      "type": "Microsoft.Compute/virtualMachines/extensions",
      "apiVersion": "2023-09-01",
      "name": "[format('{0}/{1}', variables('serverVmName'), 'install-ad-ds')]",
      "location": "[variables('location')]",
      "properties": {
        "publisher": "Microsoft.Compute",
        "type": "CustomScriptExtension",
        "typeHandlerVersion": "1.10",
        "autoUpgradeMinorVersion": true,
        "protectedSettings": {
          "commandToExecute": "[variables('installAdCommand')]"
        }
      },
      "dependsOn": [
        "[resourceId('Microsoft.Compute/virtualMachines', variables('serverVmName'))]"
      ]
    },
    {
      "condition": "[parameters('joinWorkstationToDomain')]",
      "type": "Microsoft.Compute/virtualMachines/extensions",
      "apiVersion": "2023-09-01",
      "name": "[format('{0}/{1}', variables('workstationVmName'), 'join-domain')]",
      "location": "[variables('location')]",
      "properties": {
        "publisher": "Microsoft.Compute",
        "type": "CustomScriptExtension",
        "typeHandlerVersion": "1.10",
        "autoUpgradeMinorVersion": true,
        "protectedSettings": {
          "commandToExecute": "[variables('joinDomainCommand')]"
        }
      },
      "dependsOn": [
        "[resourceId('Microsoft.Compute/virtualMachines', variables('workstationVmName'))]",
        "[resourceId('Microsoft.Compute/virtualMachines/extensions', variables('serverVmName'), 'install-ad-ds')]"
      ]
    }
  ],
  "outputs": {
    "resourceGroupName": {
      "type": "string",
      "value": "[resourceGroup().name]"
    },
    "serverVirtualMachineName": {
      "type": "string",
      "value": "[variables('serverVmName')]"
    },
    "workstationVirtualMachineName": {
      "type": "string",
      "value": "[variables('workstationVmName')]"
    },
    "serverPrivateIPAddress": {
      "type": "string",
      "value": "[variables('serverPrivateIpAddress')]"
    },
    "workstationPrivateIPAddress": {
      "type": "string",
      "value": "[variables('workstationPrivateIpAddress')]"
    },
    "serverPublicIPAddress": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.Network/publicIPAddresses', variables('serverPublicIpName')), '2023-11-01').ipAddress]"
    },
    "workstationPublicIPAddress": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.Network/publicIPAddresses', variables('workstationPublicIpName')), '2023-11-01').ipAddress]"
    },
    "serverRdpCommand": {
      "type": "string",
      "value": "[format('mstsc /v:{0}', reference(resourceId('Microsoft.Network/publicIPAddresses', variables('serverPublicIpName')), '2023-11-01').ipAddress)]"
    },
    "workstationRdpCommand": {
      "type": "string",
      "value": "[format('mstsc /v:{0}', reference(resourceId('Microsoft.Network/publicIPAddresses', variables('workstationPublicIpName')), '2023-11-01').ipAddress)]"
    },
    "activeDirectoryDomain": {
      "type": "string",
      "value": "[parameters('domainName')]"
    },
    "postDeploymentNote": {
      "type": "string",
      "value": "The server restarts after AD DS installation. If joinWorkstationToDomain is true, the workstation waits for domain DNS and then restarts after domain join."
    }
  }
}